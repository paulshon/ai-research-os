{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "noEmit": false,
    "incremental": false,
    "declarationMap": false,
    "isolatedModules": false,
    "outDir": "./dist",
    "rootDir": ".",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["electron/**/*", "preload/**/*", "filesystem/**/*", "sync/**/*"],
  "exclude": ["dist", "node_modules"]
}

{
  "name": "ai-research-os",
  "version": "0.30.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "description": "Cloud-Collaborative Local-First AI Research Operating System v30 — Complete Citation Engine with GROBID, Crossref, OpenAlex, Semantic Scholar, CSL Engine, and AI Validation",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@ai-research-os/web",
    "dev:api": "turbo dev --filter=@ai-research-os/api",
    "dev:desktop": "turbo dev --filter=@ai-research-os/desktop",
    "dev:realtime": "turbo dev --filter=@ai-research-os/realtime",
    "build": "turbo build",
    "build:web": "turbo build --filter=@ai-research-os/web",
    "build:api": "turbo build --filter=@ai-research-os/api",
    "build:desktop": "turbo build --filter=@ai-research-os/desktop",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "db:migrate": "cd apps/api && python -m alembic upgrade head",
    "db:seed": "cd apps/api && python -m scripts.seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "@changesets/cli": "^2.27.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
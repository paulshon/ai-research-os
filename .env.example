# ═══════════════════════════════════════════
# AI Research OS + RDOS v4 — Environment Configuration
# ═══════════════════════════════════════════
# 배포: Vercel(프론트) + HF Spaces(API) + Supabase(DB) + Clerk(인증) + Realtime(Hocuspocus)

# ── Clerk (인증) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
# v4: 실시간 서버·FastAPI 의 Clerk JWT 검증용(JWKS). 둘 중 하나만 설정해도 됨.
#     CLERK_ISSUER 예: https://your-app.clerk.accounts.dev
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=

# ── Supabase (DB) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 서버 전용 (웹훅·프로필 동기화·프로젝트/실시간 영속화). RLS 우회.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ── API Backend (HF Spaces) ──
API_URL=https://sarangred-ai-research-os-api.hf.space
# v4(감사 2.2): Next 프록시 → FastAPI 신뢰 경계. Next 와 FastAPI 양쪽에 동일 값 설정.
#   설정 시 Next 는 검증된 X-User-Id 를 전달하고 FastAPI 는 X-Internal-Key 일치 시 신뢰한다.
INTERNAL_API_KEY=generate-a-long-random-string

# ── Realtime (Hocuspocus 협업 서버) ──
REALTIME_PORT=1234
NEXT_PUBLIC_REALTIME_URL=ws://localhost:1234
# (실시간 서버는 CLERK_ISSUER/CLERK_JWKS_URL + SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 사용)
SUPABASE_URL=https://your-project.supabase.co

# ── App URLs ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# v4(감사 Medium): /api/* CORS 허용 출처 화이트리스트(콤마 구분). 미설정 시 APP_URL 사용.
ALLOWED_ORIGINS=http://localhost:3000

# ── Microsoft Clarity (세션 리플레이 · 히트맵 · 클릭/스크롤) ──
# https://clarity.microsoft.com → 프로젝트 생성 후 Project ID 입력
# 미설정 시 Clarity 스크립트를 로드하지 않음
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ── 관리자(Admin) ──
# v4(감사 2.3): 하드코딩 폴백 제거. 미설정 시 운영·개발 모두 관리자 로그인 불가.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# v4(감사 2.4): 관리자 세션 쿠키 HMAC 서명 + 서버-투-서버(x-admin-secret) 시크릿.
#   단일 출처(폴백 없음). 반드시 길고 임의의 값으로 설정.
ADMIN_API_SECRET=generate-a-long-random-string

# ── 슈퍼관리자 / 진입 이메일 ──
# v4(감사 Medium): 소스 하드코딩 제거 → 환경변수로. 콤마 구분 가능.
SUPER_ADMIN_EMAILS=
# 구조엔진 관리자 진입(⬡) 버튼 노출 대상(클라이언트 노출 → NEXT_PUBLIC).
NEXT_PUBLIC_ADMIN_ENTRY_EMAIL=
# 문의(contact) 폼 수신 이메일. 미설정 시 SUPER_ADMIN_EMAILS 의 첫 항목 사용.
CONTACT_ADMIN_EMAIL=

# ── AI (시스템 작업용 폴백 키) ──
GEMINI_API_KEY=
